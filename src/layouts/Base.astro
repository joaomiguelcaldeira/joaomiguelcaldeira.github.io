---
import '../styles/global.css';
import Particles from '../components/Particles.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "João Caldeira — Software Engineer",
  description = "João Caldeira — Software Engineer building full-stack, AI-powered applications. Lisbon, Portugal.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/images/jc.ico" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/hero_me.jpg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
    />
  </head>
  <body>
    <Particles />
    <div class="page">
      <slot />
    </div>

    <style>
      .page {
        position: relative;
        z-index: 1;
      }
    </style>

    <script>
      // ---- Reveal-on-scroll ----
      const revealEls = document.querySelectorAll<HTMLElement>('.reveal');
      const revealObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('in-view');
              revealObs.unobserve(e.target);
            }
          });
        },
        { threshold: 0.15 }
      );
      revealEls.forEach((el) => revealObs.observe(el));

      // ---- Active section sync for side nav (most-visible section wins) ----
      const sections = document.querySelectorAll<HTMLElement>('.section[id]');
      const dots = document.querySelectorAll<HTMLAnchorElement>('[data-nav-dot]');
      const ratios = new Map<string, number>();
      const navObs = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) =>
            ratios.set(e.target.id, e.intersectionRatio)
          );
          let best: string | null = null;
          let max = 0;
          ratios.forEach((r, id) => {
            if (r > max) {
              max = r;
              best = id;
            }
          });
          if (best) {
            dots.forEach((d) =>
              d.classList.toggle('active', d.dataset.navDot === best)
            );
          }
        },
        { threshold: [0, 0.25, 0.5, 0.75, 1] }
      );
      sections.forEach((s) => navObs.observe(s));

      // ---- Magnetic buttons ----
      const magnets = document.querySelectorAll<HTMLElement>('[data-magnetic]');
      const canHover = window.matchMedia('(hover: hover)').matches;
      if (canHover) {
        magnets.forEach((m) => {
          m.addEventListener('pointermove', (e) => {
            const r = m.getBoundingClientRect();
            const x = e.clientX - r.left - r.width / 2;
            const y = e.clientY - r.top - r.height / 2;
            m.style.transform = `translate(${x * 0.25}px, ${y * 0.35}px)`;
          });
          m.addEventListener('pointerleave', () => {
            m.style.transform = '';
          });
        });
      }
    </script>
  </body>
</html>
