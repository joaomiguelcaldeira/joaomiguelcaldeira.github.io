---
const stack: { label: string; items: string[]; lead?: boolean }[] = [
  { label: 'AI / ML', lead: true, items: ['PyTorch', 'Hugging Face', 'Ollama', 'LLMs & RAG', 'NLP', 'Computer Vision'] },
  { label: 'Web & APIs', items: ['FastAPI', 'Node.js', '.NET', 'React', 'Next.js', 'Astro'] },
  { label: 'Cloud & DevOps', items: ['GCP', 'AWS', 'Docker', 'PostgreSQL', 'CI/CD'] },
  { label: 'Languages', items: ['Python', 'TypeScript', 'SQL', 'Java', 'C / C++'] },
];
---

<section id="about" class="section about">
  <div class="section-inner">
    <p class="eyebrow reveal">01 / About</p>
    <h2 class="section-title reveal">A bit about <span>me</span></h2>

    <div class="about-grid">
      <div class="about-bio">
        <p class="about-lead reveal">
          Lately I'm just as focused on <em>how</em> I build as <em>what</em> I
          build, squeezing the most out of <span>coding agents</span> and new AI
          tooling to make my day-to-day workflow faster and sharper.
        </p>
        <p class="reveal" style="--reveal-delay: 80ms">
          Financial markets have a particular grip on me: my MSc thesis dug
          into ML models for predicting market trends, and I've been hooked on
          <span>trading systems</span> ever since.
        </p>
        <p class="reveal" style="--reveal-delay: 160ms">
          Away from the keyboard, I'm usually reading about space exploration,
          putting in work at the gym, or three tabs deep in the latest AI news.
        </p>
        <p class="about-facts reveal" style="--reveal-delay: 240ms">
          Based in Lisbon &nbsp;·&nbsp; MSc in Computer Science &amp; Engineering
        </p>
      </div>

      <aside class="about-stack reveal" style="--reveal-delay: 160ms">
        <div class="cmdk" id="toolkit-cmdk">
          <div class="cmdk-bar">
            <span class="cmdk-prompt">/</span>
            <input
              type="text"
              class="cmdk-input"
              id="cmdk-input"
              placeholder="Search my toolkit…"
              autocomplete="off"
              spellcheck="false"
              aria-label="Search technologies"
            />
            <span class="cmdk-kbd"><kbd>⌘</kbd><kbd>K</kbd></span>
          </div>
          <div class="cmdk-list" id="cmdk-list" role="listbox" aria-label="Toolkit">
            {
              stack.map((g) => (
                <div class={`cmdk-group${g.lead ? ' lead' : ''}`} data-group>
                  <div class="cmdk-group-label">{g.label}</div>
                  {g.items.map((it) => (
                    <div class="cmdk-item" role="option" data-name={it.toLowerCase()}>
                      <span class="cmdk-item-name">{it}</span>
                      <span class="cmdk-item-go">↵</span>
                    </div>
                  ))}
                </div>
              ))
            }
            <div class="cmdk-empty" id="cmdk-empty" hidden>No matches.</div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  /* Bio */
  .about-bio {
    position: relative;
    padding-left: 1.8rem;
  }
  .about-bio::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.35rem;
    bottom: 0.35rem;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(
      to bottom,
      var(--accent),
      var(--accent-2),
      transparent
    );
  }
  .about-lead {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.3vw, 1.65rem);
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .about-lead span {
    color: var(--accent);
  }
  .about-bio p {
    color: var(--text-muted);
    margin-bottom: 1.1rem;
    max-width: 58ch;
    line-height: 1.75;
  }
  .about-bio p span {
    color: var(--accent);
    font-weight: 500;
  }
  .about-facts {
    font-size: 0.88rem;
    color: var(--text-dim);
    margin-top: 1.7rem;
    margin-bottom: 0;
  }
  .about-facts a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
    transition: text-decoration-color var(--t-fast);
  }
  .about-facts a:hover {
    text-decoration-color: var(--accent);
  }

  /* Toolkit: command palette */
  .cmdk {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 70%, transparent);
    backdrop-filter: blur(8px);
    overflow: hidden;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .cmdk:focus-within {
    border-color: var(--accent);
    box-shadow: 0 20px 50px -28px var(--accent-glow);
  }

  .cmdk-bar {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.75rem 0.9rem;
    border-bottom: 1px solid var(--border);
  }
  .cmdk-prompt {
    font-family: var(--font-mono);
    color: var(--accent);
    font-size: 1rem;
    line-height: 1;
  }
  .cmdk-input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: none;
    outline: none;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.9rem;
    caret-color: var(--accent);
  }
  .cmdk-input::placeholder {
    color: var(--text-dim);
  }
  .cmdk-kbd {
    display: inline-flex;
    gap: 0.2rem;
    flex-shrink: 0;
  }
  .cmdk-kbd kbd {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text-dim);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 5px;
    padding: 0.1rem 0.35rem;
    line-height: 1.3;
  }

  .cmdk-list {
    max-height: clamp(260px, 42vh, 380px);
    overflow-y: auto;
    padding: 0.4rem;
    scrollbar-width: thin;
    scrollbar-color: var(--border-strong) transparent;
  }
  .cmdk-list::-webkit-scrollbar {
    width: 8px;
  }
  .cmdk-list::-webkit-scrollbar-thumb {
    background: var(--border-strong);
    border-radius: 99px;
  }

  .cmdk-group {
    margin-bottom: 0.4rem;
  }
  .cmdk-group[hidden] {
    display: none;
  }
  .cmdk-group-label {
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding: 0.5rem 0.6rem 0.35rem;
  }
  .cmdk-group.lead .cmdk-group-label {
    color: var(--accent);
  }

  .cmdk-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.6rem;
    padding: 0.5rem 0.6rem;
    border-radius: 8px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-muted);
    cursor: default;
    border-left: 2px solid transparent;
    transition: background var(--t-fast), color var(--t-fast),
      border-color var(--t-fast);
  }
  .cmdk-item[hidden] {
    display: none;
  }
  .cmdk-item-go {
    opacity: 0;
    color: var(--accent);
    font-size: 0.8rem;
    transition: opacity var(--t-fast);
  }
  .cmdk-item.active {
    background: var(--accent-soft);
    color: var(--text);
    border-left-color: var(--accent);
  }
  .cmdk-item.active .cmdk-item-go {
    opacity: 1;
  }

  .cmdk-empty {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--text-dim);
    padding: 1rem 0.6rem;
    text-align: center;
  }
  .cmdk-empty[hidden] {
    display: none;
  }

  @media (max-width: 820px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.2rem;
    }
    .about-bio {
      padding-left: 1.2rem;
    }
  }
</style>

<script is:inline>
  (function () {
    var input = document.getElementById('cmdk-input');
    var list = document.getElementById('cmdk-list');
    var empty = document.getElementById('cmdk-empty');
    if (!input || !list) return;

    var items = Array.prototype.slice.call(list.querySelectorAll('.cmdk-item'));
    var groups = Array.prototype.slice.call(list.querySelectorAll('.cmdk-group'));
    var active = -1;

    function visible() {
      return items.filter(function (it) {
        return !it.hidden;
      });
    }

    function setActive(idx) {
      var vis = visible();
      items.forEach(function (it) {
        it.classList.remove('active');
      });
      if (!vis.length) {
        active = -1;
        return;
      }
      if (idx < 0) idx = vis.length - 1;
      if (idx >= vis.length) idx = 0;
      active = idx;
      vis[idx].classList.add('active');
      vis[idx].scrollIntoView({ block: 'nearest' });
    }

    function filter() {
      var q = input.value.trim().toLowerCase();
      items.forEach(function (it) {
        var match = !q || it.getAttribute('data-name').indexOf(q) !== -1;
        it.hidden = !match;
      });
      groups.forEach(function (g) {
        g.hidden = !g.querySelector('.cmdk-item:not([hidden])');
      });
      var vis = visible();
      empty.hidden = vis.length > 0;
      setActive(vis.length ? 0 : -1);
    }

    input.addEventListener('input', filter);
    input.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        setActive(active + 1);
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        setActive(active - 1);
      } else if (e.key === 'Escape') {
        input.value = '';
        filter();
      }
    });

    items.forEach(function (it) {
      it.addEventListener('mouseenter', function () {
        var idx = visible().indexOf(it);
        if (idx >= 0) setActive(idx);
      });
    });

    // ⌘K / Ctrl+K to focus the palette
    document.addEventListener('keydown', function (e) {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        input.focus({ preventScroll: true });
      }
    });

    filter();
  })();
</script>
