---
const logoData: { name: string; slug: string; x: number; y: number; anim: string; dur: number; color?: string }[] = [
  { name: 'Python',          slug: 'python',        x: 5,  y: 8,  anim: 'a', dur: 14 },
  { name: 'GitHub',          slug: 'github',        x: 58, y: 5,  anim: 'b', dur: 17, color: 'e9e9f0' },
  { name: 'PyTorch',         slug: 'pytorch',       x: 78, y: 20, anim: 'c', dur: 13 },
  { name: 'Redis',           slug: 'redis',         x: 30, y: 15, anim: 'a', dur: 16 },
  { name: 'Claude Code',     slug: 'claudecode',    x: 48, y: 28, anim: 'a', dur: 16 },
  { name: 'Next.js',         slug: 'nextdotjs',     x: 10, y: 42, anim: 'b', dur: 19, color: 'e9e9f0' },
  { name: 'GitHub Actions',  slug: 'githubactions', x: 68, y: 44, anim: 'a', dur: 15 },
  { name: 'Hugging Face',    slug: 'huggingface',   x: 48, y: 62, anim: 'c', dur: 18 },
  { name: 'Docker',          slug: 'docker',        x: 80, y: 62, anim: 'b', dur: 20 },
  { name: 'GCP',             slug: 'googlecloud',   x: 30, y: 80, anim: 'c', dur: 16 },
  { name: 'Vercel',          slug: 'vercel',        x: 63, y: 76, anim: 'a', dur: 14, color: 'e9e9f0' },
  { name: 'PostgreSQL',      slug: 'postgresql',    x: 76, y: 82, anim: 'b', dur: 17 },
  { name: '.NET',            slug: 'dotnet',        x: 20, y: 55, anim: 'b', dur: 19 },
];
const logos = logoData.map((l, i) => ({ ...l, delay: -(i * 1.5) }));
---

<section id="about" class="section about">
  <div class="section-inner">
    <p class="eyebrow reveal">01 / About</p>
    <h2 class="section-title reveal">A bit about <span>me</span></h2>

    <div class="about-grid">
      <div class="about-bio">
        <p class="about-lead reveal">
          Lately I'm just as focused on <em>how</em> I build as <em>what</em> I
          build, squeezing the most out of <span>coding agents</span> and new AI
          tooling to make my day-to-day workflow faster and sharper.
        </p>
        <p class="reveal" style="--reveal-delay: 80ms">
          Financial markets have a particular grip on me: my MSc thesis dug
          into ML models for predicting market trends, and I've been hooked on
          <span>trading systems</span> ever since.
        </p>
        <p class="reveal" style="--reveal-delay: 160ms">
          Away from the keyboard, I'm usually reading about space exploration,
          putting in work at the gym, or three tabs deep in the latest AI news.
        </p>
        <p class="about-facts reveal" style="--reveal-delay: 240ms">
          Based in Lisbon &nbsp;·&nbsp; MSc in Computer Science &amp; Engineering
        </p>
      </div>

      <aside class="about-stack reveal" style="--reveal-delay: 160ms" aria-label="Technologies">
        <div class="logo-cloud">
          {logos.map((l) => (
            <span
              class={`logo-float anim-${l.anim}`}
              data-label={l.name}
              style={`left:${l.x}%; top:${l.y}%; animation-duration:${l.dur}s; animation-delay:${l.delay}s`}
            >
              <img
                src={`https://cdn.simpleicons.org/${l.slug}${l.color ? '/' + l.color : ''}`}
                alt={l.name}
                width="32"
                height="32"
                loading="lazy"
              />
            </span>
          ))}
        </div>
      </aside>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  /* Bio */
  .about-bio {
    position: relative;
    padding-left: 1.8rem;
  }
  .about-bio::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.35rem;
    bottom: 0.35rem;
    width: 2px;
    border-radius: 2px;
    background: linear-gradient(
      to bottom,
      var(--accent),
      var(--accent-2),
      transparent
    );
  }
  .about-lead {
    font-family: var(--font-display);
    font-size: clamp(1.3rem, 2.3vw, 1.65rem);
    line-height: 1.4;
    color: var(--text);
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .about-lead span {
    color: var(--accent);
  }
  .about-bio p {
    color: var(--text-muted);
    margin-bottom: 1.1rem;
    max-width: 58ch;
    line-height: 1.75;
  }
  .about-bio p span {
    color: var(--accent);
    font-weight: 500;
  }
  .about-facts {
    font-size: 0.88rem;
    color: var(--text-dim);
    margin-top: 1.7rem;
    margin-bottom: 0;
  }

  /* Floating logo cloud */
  .about-stack {
    height: 100%;
  }
  .logo-cloud {
    position: relative;
    width: 100%;
    height: 400px;
  }

  .logo-float {
    position: absolute;
    width: 32px;
    height: 32px;
    cursor: default;
    will-change: transform;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  .logo-float img {
    width: 100%;
    height: 100%;
    opacity: 0.45;
    filter: grayscale(0.6) brightness(0.85);
    transition: opacity var(--t-fast), filter var(--t-fast), transform var(--t-fast);
    display: block;
  }
  .logo-float:hover img {
    opacity: 1;
    filter: grayscale(0) drop-shadow(0 0 10px rgba(var(--accent-rgb), 0.55));
    transform: scale(1.3);
  }

  /* Tooltip */
  .logo-float::after {
    content: attr(data-label);
    position: absolute;
    bottom: calc(100% + 7px);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--text);
    background: var(--surface-2);
    border: 1px solid var(--border-strong);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--t-fast);
    z-index: 20;
  }
  .logo-float:hover::after {
    opacity: 1;
  }

  /* Float paths */
  .logo-float.anim-a { animation-name: float-a; }
  .logo-float.anim-b { animation-name: float-b; }
  .logo-float.anim-c { animation-name: float-c; }

  @keyframes float-a {
    0%,  100% { transform: translate(0px,    0px); }
    25%        { transform: translate(10px,  -14px); }
    50%        { transform: translate(-6px,  -22px); }
    75%        { transform: translate(14px,   -8px); }
  }
  @keyframes float-b {
    0%,  100% { transform: translate(0px,    0px); }
    30%        { transform: translate(-12px,  16px); }
    65%        { transform: translate(10px,  -14px); }
  }
  @keyframes float-c {
    0%,  100% { transform: translate(0px,    0px); }
    35%        { transform: translate(16px,   18px); }
    70%        { transform: translate(-8px,    8px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .logo-float { animation: none; }
  }

  @media (max-width: 820px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 2.2rem;
    }
    .about-bio {
      padding-left: 1.2rem;
    }
    .logo-cloud {
      height: 280px;
    }
  }
</style>
