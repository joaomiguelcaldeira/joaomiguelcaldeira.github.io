---
---

<section id="contact" class="section contact">
  <div class="section-inner contact-inner">
    <p class="eyebrow reveal">04 / Contact</p>
    <h2 class="section-title reveal">Let's <span>build something</span></h2>
    <p class="contact-lead reveal" style="--reveal-delay: 80ms">
      Got a project, an opportunity, or just want to say hi? My inbox is always open.
    </p>

    <div class="contact-card reveal" style="--reveal-delay: 160ms">
      <form
        action="https://formspree.io/f/mldjrzvl"
        method="POST"
        class="contact-form"
        id="contactForm"
      >
        <div class="field">
          <input type="email" name="email" required placeholder=" " id="cf-email" />
          <label for="cf-email">Your email</label>
        </div>
        <div class="field">
          <textarea name="message" required placeholder=" " id="cf-msg" rows="4"></textarea>
          <label for="cf-msg">Your message</label>
        </div>
        <button type="submit" class="btn btn-primary" data-magnetic>
          <i class="fas fa-paper-plane"></i> Send message
        </button>
      </form>
      <p class="contact-status" id="contactStatus" hidden></p>
    </div>

    <div class="contact-socials reveal" style="--reveal-delay: 240ms">
      <a href="https://github.com/joaomiguelcaldeira" target="_blank" aria-label="GitHub"><i class="fab fa-github"></i></a>
      <a href="https://www.linkedin.com/in/joao-miguel-caldeira/" target="_blank" aria-label="LinkedIn"><i class="fab fa-linkedin-in"></i></a>
      <a href="mailto:joaomiguel.caldeira@gmail.com" aria-label="Email"><i class="fas fa-envelope"></i></a>
    </div>

    <footer class="footer">
      © {new Date().getFullYear()} João Caldeira · Built with Astro
    </footer>
  </div>
</section>

<style>
  .contact {
    justify-content: center;
  }
  .contact-inner {
    max-width: 600px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .contact-lead {
    color: var(--text-muted);
    max-width: 44ch;
    margin-bottom: 2.2rem;
  }
  .contact-card {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.4rem;
  }
  .field {
    position: relative;
    text-align: left;
  }
  .field input,
  .field textarea {
    width: 100%;
    padding: 1rem 1rem 0.6rem;
    background: var(--bg-2);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    resize: vertical;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .field label {
    position: absolute;
    left: 1rem;
    top: 0.85rem;
    color: var(--text-dim);
    font-size: 0.95rem;
    pointer-events: none;
    transition: all var(--t-fast);
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .field input:focus + label,
  .field input:not(:placeholder-shown) + label,
  .field textarea:focus + label,
  .field textarea:not(:placeholder-shown) + label {
    top: 0.3rem;
    font-size: 0.68rem;
    color: var(--accent);
    letter-spacing: 0.04em;
  }
  .contact-form .btn {
    align-self: center;
    margin-top: 0.3rem;
  }
  .contact-form,
  .contact-status {
    transition: opacity 0.5s var(--ease);
  }
  .contact-status {
    margin-top: 1.2rem;
    font-size: 1.05rem;
    color: var(--accent);
  }
  .contact-socials {
    display: flex;
    gap: 1.6rem;
    font-size: 1.5rem;
    margin: 2.2rem 0 1.5rem;
  }
  .contact-socials a {
    color: var(--text-muted);
    transition: color var(--t-fast), transform var(--t-fast);
  }
  .contact-socials a:hover {
    color: var(--accent);
    transform: translateY(-3px);
  }
  .footer {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
  }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById('contactForm');
    var status = document.getElementById('contactStatus');
    if (!form || !status) return;

    var messages = [
      '✅ Message received! I\'ll be in touch.',
      '🚀 Transmission successful. Talk soon!',
      '✨ Got it! Appreciate you reaching out.',
    ];

    function fadeIn(el) {
      el.hidden = false;
      el.style.opacity = '0';
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          el.style.opacity = '1';
        });
      });
    }

    function fadeOut(el, cb) {
      el.style.opacity = '0';
      setTimeout(function () {
        el.hidden = true;
        el.style.opacity = '';
        if (cb) cb();
      }, 500);
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      var data = new FormData(form);
      var btn = form.querySelector('button[type="submit"]');
      if (btn) { btn.disabled = true; btn.style.opacity = '0.6'; }

      try {
        var res = await fetch(form.action, {
          method: 'POST',
          body: data,
          headers: { Accept: 'application/json' },
        });
        if (res.ok) {
          status.style.color = '';
          status.textContent = messages[Math.floor(Math.random() * messages.length)];
          fadeOut(form, function () {
            fadeIn(status);
            setTimeout(function () {
              fadeOut(status, function () {
                form.reset();
                if (btn) { btn.disabled = false; btn.style.opacity = ''; }
                fadeIn(form);
              });
            }, 4000);
          });
        } else {
          throw new Error('bad response');
        }
      } catch (err) {
        status.style.color = '#ff6b6b';
        status.textContent = '⚠️ Something went wrong. Try emailing me directly.';
        fadeIn(status);
        if (btn) { btn.disabled = false; btn.style.opacity = ''; }
      }
    });
  })();
</script>
