---
const roles = ['Software Engineer', 'AI Enthusiast', 'Problem Solver', 'Algorithmic Trader (allegedly)'];
---

<section id="home" class="section hero">
  <div class="section-inner hero-grid">
    <div class="hero-photo reveal">
      <div class="photo-ring">
        <img src="/images/hero_me.jpg" alt="João Caldeira" />
      </div>
      <div class="location">
        <i class="fas fa-location-dot"></i><span>Lisbon, Portugal</span>
      </div>
      <div class="hero-socials">
        <a href="https://github.com/joaomiguelcaldeira" target="_blank" aria-label="GitHub">
          <i class="fab fa-github"></i>
        </a>
        <a href="https://www.linkedin.com/in/joao-miguel-caldeira/" target="_blank" aria-label="LinkedIn">
          <i class="fab fa-linkedin-in"></i>
        </a>
        <a href="mailto:joaomiguel.caldeira@gmail.com" aria-label="Email">
          <i class="fas fa-envelope"></i>
        </a>
      </div>
    </div>

    <div class="hero-text">
      <p class="eyebrow reveal">Hi there, I'm</p>
      <h1 class="hero-name reveal" style="--reveal-delay: 80ms">João Caldeira</h1>
      <p class="hero-role reveal" style="--reveal-delay: 160ms">
        <span class="role-prefix"><span id="role-article">a</span></span>
        <span id="role-rotator" class="role-rotator"></span>
      </p>
      <p class="hero-tagline reveal" style="--reveal-delay: 240ms">
        Mostly I build things, break things, and automate the boring parts, and
        somewhere in there I fell for trading systems.
      </p>

      <div class="hero-actions reveal" style="--reveal-delay: 320ms">
        <a class="btn btn-primary" href="#contact" data-magnetic>
          <i class="fas fa-paper-plane"></i> Get in touch
        </a>
        <a class="btn" href="/content/joao-caldeira-resume.pdf" target="_blank" data-magnetic>
          <i class="fas fa-file-arrow-down"></i> CV
        </a>
      </div>

      <a
        class="hero-badge reveal"
        style="--reveal-delay: 380ms"
        href="https://doi.org/10.1007/s10614-025-11252-0"
        target="_blank"
        rel="noopener"
      >
        <i class="fas fa-newspaper hero-badge-icon"></i>
        <span class="hero-badge-text">
          Published in <strong>Computational Economics</strong> (Springer)
        </span>
        <i class="fas fa-arrow-up-right-from-square hero-badge-ext"></i>
      </a>
    </div>
  </div>

  <a href="#about" class="scroll-cue" aria-label="Scroll to about">
    <span></span>
  </a>
</section>

<style>
  .hero {
    justify-content: center;
  }

  .hero-badge {
    display: flex;
    width: fit-content;
    max-width: 100%;
    align-items: center;
    gap: 0.6rem;
    padding: 0.45rem 0.95rem;
    margin-top: 1.6rem;
    border-radius: 99px;
    border: 1px solid var(--border-strong);
    background: var(--surface);
    font-size: 0.82rem;
    color: var(--text-muted);
    transition: border-color var(--t-fast), transform var(--t-fast),
      box-shadow var(--t-fast), color var(--t-fast);
  }
  .hero-badge:hover {
    color: var(--text);
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px -12px var(--accent-glow);
  }
  .hero-badge-icon {
    font-size: 1rem;
    color: var(--accent);
    flex-shrink: 0;
  }
  .hero-badge strong {
    color: var(--text);
    font-weight: 600;
  }
  .hero-badge-ext {
    font-size: 0.7rem;
    color: var(--text-dim);
  }
  .hero-badge:hover .hero-badge-ext {
    color: var(--accent);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: center;
    gap: clamp(2rem, 6vw, 5rem);
    position: relative;
    z-index: 1;
  }

  .hero-photo {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }
  .photo-ring {
    position: relative;
    isolation: isolate;
    width: clamp(180px, 22vw, 260px);
    aspect-ratio: 1;
    border-radius: 50%;
    transition: transform var(--t-mid);
    will-change: transform;
  }
  /* Soft accent glow that gently breathes behind the photo */
  .photo-ring::before {
    content: '';
    position: absolute;
    inset: -14%;
    z-index: -1;
    border-radius: 50%;
    background: radial-gradient(
      circle,
      var(--accent-glow) 0%,
      transparent 68%
    );
    will-change: transform, opacity;
    animation: glow-breathe 4.5s ease-in-out infinite;
  }
  @keyframes glow-breathe {
    0%,
    100% {
      opacity: 0.45;
      transform: scale(0.92);
    }
    50% {
      opacity: 0.9;
      transform: scale(1.08);
    }
  }
  .photo-ring:hover {
    transform: translateY(-6px);
  }
  .photo-ring img {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    display: block;
    border: 1px solid var(--border-strong);
    transform: translateZ(0);
    backface-visibility: hidden;
  }
  @media (prefers-reduced-motion: reduce) {
    .photo-ring::before {
      animation: none;
    }
  }
  .location {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .location i {
    color: var(--accent);
  }

  .hero-name {
    font-size: clamp(2.6rem, 7vw, 4.6rem);
    margin: 0.4rem 0 0.6rem;
  }
  .hero-role {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: var(--text-muted);
    display: flex;
    gap: 0.5ch;
    flex-wrap: wrap;
    align-items: baseline;
    min-height: 1.4em;
  }
  .role-rotator {
    color: var(--accent);
    font-weight: 600;
    position: relative;
  }
  .role-rotator::after {
    content: '';
    display: inline-block;
    width: 2px;
    height: 1em;
    background: var(--accent);
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .hero-tagline {
    max-width: 46ch;
    color: var(--text-muted);
    margin: 1.4rem 0 2rem;
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero-socials {
    display: flex;
    gap: 1.4rem;
    margin-top: 0.9rem;
    font-size: 1.3rem;
  }
  .hero-socials a {
    color: var(--text-muted);
    transition: color var(--t-fast), transform var(--t-fast);
  }
  .hero-socials a:hover {
    color: var(--accent);
    transform: translateY(-3px);
  }

  .scroll-cue {
    position: absolute;
    bottom: 1.8rem;
    left: 50%;
    transform: translateX(-50%);
    width: 26px;
    height: 42px;
    border: 2px solid var(--border-strong);
    border-radius: 99px;
    display: flex;
    justify-content: center;
    padding-top: 7px;
  }
  .scroll-cue span {
    width: 4px;
    height: 8px;
    border-radius: 99px;
    background: var(--accent);
    animation: scrollDot 1.6s var(--ease) infinite;
  }
  @keyframes scrollDot {
    0% {
      transform: translateY(0);
      opacity: 1;
    }
    70% {
      transform: translateY(14px);
      opacity: 0;
    }
    100% {
      opacity: 0;
    }
  }

  @media (max-width: 820px) {
    .hero-grid {
      grid-template-columns: 1fr;
      text-align: center;
      justify-items: center;
      gap: 1.5rem;
    }
    .photo-ring {
      width: clamp(110px, 28vw, 150px);
    }
    .hero-role,
    .hero-actions,
    .hero-socials {
      justify-content: center;
    }
    .hero-tagline {
      margin-inline: auto;
    }
    .hero-badge {
      margin-inline: auto;
      flex-wrap: wrap;
      justify-content: center;
      text-align: center;
    }
    .scroll-cue {
      display: none;
    }
  }
</style>

<script is:inline define:vars={{ roles }}>
  (function () {
    var el = document.getElementById('role-rotator');
    var article = document.getElementById('role-article');
    if (!el) return;
    var words = roles && roles.length ? roles : ['Software Engineer'];
    var wi = 0,
      ci = 0,
      deleting = false;

    function tick() {
      var word = words[wi];
      if (article)
        article.textContent = /^[aeiou]/i.test(word) ? 'an' : 'a';
      el.textContent = word.slice(0, ci);

      if (!deleting && ci < word.length) {
        ci++;
        setTimeout(tick, 70);
      } else if (!deleting && ci === word.length) {
        deleting = true;
        setTimeout(tick, 1400);
      } else if (deleting && ci > 0) {
        ci--;
        setTimeout(tick, 35);
      } else {
        deleting = false;
        wi = (wi + 1) % words.length;
        setTimeout(tick, 250);
      }
    }
    tick();
  })();
</script>
