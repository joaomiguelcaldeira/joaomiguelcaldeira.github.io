---
import { experience } from '../data/experience.ts';
---

<section id="experience" class="section experience">
  <div class="section-inner">
    <p class="eyebrow reveal">02 — Experience</p>
    <h2 class="section-title reveal">Where I've <span>worked & studied</span></h2>

    <ol class="timeline">
      {
        experience.map((item, i) => (
          <li class="tl-item reveal" style={`--reveal-delay: ${i * 70}ms`}>
            <span class={`tl-node ${item.kind}`}>
              <i class={`fas ${item.kind === 'work' ? 'fa-briefcase' : 'fa-graduation-cap'}`} />
            </span>
            <div class="tl-card">
              <div class="tl-head">
                <div>
                  <h3>{item.role}</h3>
                  <a class="tl-org" href={item.url} target="_blank" rel="noopener">
                    {item.org}
                  </a>
                </div>
                <span class="tl-period">{item.period}</span>
              </div>
              <ul class="tl-points">
                {item.points.map((p) => (
                  <li>{p}</li>
                ))}
              </ul>
              <div class="tl-tags">
                {item.tags.map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .timeline {
    list-style: none;
    position: relative;
    padding-left: 2.4rem;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 11px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: linear-gradient(
      to bottom,
      var(--accent),
      var(--accent-2),
      transparent
    );
  }
  .tl-item {
    position: relative;
    padding-bottom: 1.5rem;
  }
  .tl-item:last-child {
    padding-bottom: 0;
  }
  .tl-node {
    position: absolute;
    left: -2.4rem;
    top: 2px;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    font-size: 0.62rem;
    background: var(--bg-2);
    border: 2px solid var(--accent);
    color: var(--accent);
    z-index: 1;
  }
  .tl-node.education {
    border-color: var(--accent-2);
    color: var(--accent-2);
  }

  .tl-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.1rem 1.3rem;
    transition: border-color var(--t-fast), transform var(--t-fast),
      box-shadow var(--t-fast);
  }
  .tl-card:hover {
    border-color: var(--border-strong);
    transform: translateX(4px);
    box-shadow: 0 14px 40px -24px var(--accent-glow);
  }
  .tl-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.6rem;
  }
  .tl-head h3 {
    font-size: 1.08rem;
  }
  .tl-org {
    font-size: 0.9rem;
    color: var(--accent);
  }
  .tl-org:hover {
    text-decoration: underline;
  }
  .tl-period {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-dim);
    white-space: nowrap;
    flex-shrink: 0;
  }
  .tl-points {
    margin: 0 0 0.8rem 1.1rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }
  .tl-points li {
    margin-bottom: 0.35rem;
  }
  .tl-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  @media (max-width: 820px) {
    .tl-head {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
