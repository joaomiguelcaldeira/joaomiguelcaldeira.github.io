---
import { experience } from '../data/experience.ts';

// keep the original data order but render the tab rail grouped
const work = experience
  .map((item, i) => ({ item, i }))
  .filter((x) => x.item.kind === 'work');
const education = experience
  .map((item, i) => ({ item, i }))
  .filter((x) => x.item.kind === 'education');
const groups = [
  { label: 'Work', entries: work },
  { label: 'Education', entries: education },
];
---

<section id="experience" class="section experience">
  <div class="section-inner">
    <p class="eyebrow reveal">02 / Experience</p>
    <h2 class="section-title reveal">Where I've <span>worked & studied</span></h2>

    <div class="xp reveal">
      <!-- Custom dropdown (mobile only) -->
      <div class="xp-dropdown" id="xp-dropdown">
        <button class="xp-dropdown-trigger" id="xp-dropdown-trigger" aria-expanded="false" aria-haspopup="listbox" type="button">
          <span class="xp-dropdown-left">
            <span class="xp-dropdown-logo">
              <img src={experience[0].logo} alt="" id="xp-dropdown-img" loading="lazy" />
            </span>
            <span class="xp-dropdown-label" id="xp-dropdown-label">
              <span class="xp-dropdown-role">{experience[0].short}</span>
              <span class="xp-dropdown-org">{experience[0].org}</span>
            </span>
          </span>
          <i class="fas fa-chevron-down xp-dropdown-chevron"></i>
        </button>
        <ul class="xp-dropdown-menu" id="xp-dropdown-menu" role="listbox" hidden>
          {experience.map((item, i) => (
            <li
              class="xp-dropdown-item"
              role="option"
              data-idx={i}
              aria-selected={i === 0 ? 'true' : 'false'}
            >
              <span class="xp-dropdown-item-logo">
                <img src={item.logo} alt="" loading="lazy" />
              </span>
              <span class="xp-dropdown-item-text">
                <span class="xp-dropdown-item-role">{item.short}</span>
                <span class="xp-dropdown-item-org">{item.org}</span>
              </span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Tab rail (desktop) -->
      <div class="xp-tabs" role="tablist" aria-label="Roles and education">
        {
          groups.map((g) => (
            <div class="xp-group">
              <span class="xp-group-label">{g.label}</span>
              {g.entries.map(({ item, i }) => (
                <button
                  class="xp-tab"
                  role="tab"
                  id={`xp-tab-${i}`}
                  aria-controls={`xp-panel-${i}`}
                  aria-selected={i === 0 ? 'true' : 'false'}
                  tabindex={i === 0 ? 0 : -1}
                  data-idx={i}
                >
                  <span class="xp-tab-logo">
                    <img src={item.logo} alt="" loading="lazy" />
                  </span>
                  <span class="xp-tab-text">
                    <span class="xp-tab-role">{item.short}</span>
                    <span class="xp-tab-org">{item.org}</span>
                  </span>
                </button>
              ))}
            </div>
          ))
        }
      </div>

      <!-- Panels -->
      <div class="xp-panels">
        {
          experience.map((item, i) => (
            <div
              class="xp-panel"
              role="tabpanel"
              id={`xp-panel-${i}`}
              aria-labelledby={`xp-tab-${i}`}
              hidden={i !== 0}
            >
              <div class="xp-panel-head">
                <div class="xp-panel-titles">
                  <h3>
                    {item.role}
                    <span class={`xp-badge ${item.kind}`}>
                      {item.kind === 'work' ? 'Work' : 'Education'}
                    </span>
                  </h3>
                  <a class="xp-org" href={item.url} target="_blank" rel="noopener">
                    {item.org} <i class="fas fa-arrow-up-right-from-square" />
                  </a>
                </div>
                <span class="xp-period">{item.period}</span>
              </div>
              <ul class="xp-points">
                {item.points.map((p) => (
                  <li set:html={p} />
                ))}
              </ul>
              <div class="xp-tags">
                {item.tags.map((t) => (
                  <span class="tag">{t}</span>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .xp {
    display: grid;
    grid-template-columns: 270px 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ---- Custom dropdown (hidden on desktop) ---- */
  .xp-dropdown {
    display: none;
    position: relative;
  }
  .xp-dropdown-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.7rem 0.9rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    color: var(--text);
    font-family: var(--font-sans);
    cursor: pointer;
    text-align: left;
    transition: border-color var(--t-fast), box-shadow var(--t-fast);
  }
  .xp-dropdown-trigger:hover,
  .xp-dropdown-trigger[aria-expanded='true'] {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .xp-dropdown-left {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
  }
  .xp-dropdown-logo {
    flex-shrink: 0;
    width: 30px;
    height: 30px;
    border-radius: 7px;
    background: rgba(255, 255, 255, 0.92);
    display: grid;
    place-items: center;
    padding: 3px;
  }
  .xp-dropdown-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .xp-dropdown-label {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .xp-dropdown-role {
    font-weight: 600;
    font-size: 0.9rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .xp-dropdown-org {
    font-size: 0.75rem;
    color: var(--text-dim);
  }
  .xp-dropdown-chevron {
    font-size: 0.72rem;
    color: var(--text-dim);
    flex-shrink: 0;
    transition: transform var(--t-fast);
  }
  .xp-dropdown-trigger[aria-expanded='true'] .xp-dropdown-chevron {
    transform: rotate(180deg);
  }
  .xp-dropdown-menu {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--bg-2);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    overflow: hidden;
    z-index: 100;
    box-shadow: 0 12px 40px -8px rgba(0, 0, 0, 0.5);
  }
  .xp-dropdown-menu[hidden] {
    display: none;
  }
  .xp-dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    padding: 0.65rem 0.9rem;
    cursor: pointer;
    transition: background var(--t-fast);
    list-style: none;
  }
  .xp-dropdown-item:hover {
    background: var(--surface);
  }
  .xp-dropdown-item[aria-selected='true'] {
    background: var(--accent-soft);
  }
  .xp-dropdown-item-logo {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.92);
    display: grid;
    place-items: center;
    padding: 3px;
  }
  .xp-dropdown-item-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .xp-dropdown-item-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .xp-dropdown-item-role {
    font-weight: 600;
    font-size: 0.88rem;
  }
  .xp-dropdown-item-org {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  /* ---- Tab rail ---- */
  .xp-tabs {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .xp-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .xp-group-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding-left: 0.3rem;
    margin-bottom: 0.2rem;
  }
  .xp-tab {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    width: 100%;
    text-align: left;
    padding: 0.7rem 0.85rem;
    border: 1px solid transparent;
    border-left: 2px solid var(--border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: background var(--t-fast), border-color var(--t-fast),
      color var(--t-fast), transform var(--t-fast);
  }
  .xp-tab:hover {
    background: var(--surface);
    color: var(--text);
    transform: translateX(2px);
  }
  .xp-tab[aria-selected='true'] {
    background: var(--surface-2);
    border-left-color: var(--accent);
    color: var(--text);
    box-shadow: -8px 0 24px -18px var(--accent-glow);
  }
  .xp-tab-logo {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.92);
    display: grid;
    place-items: center;
    padding: 4px;
  }
  .xp-tab-logo img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .xp-tab-text {
    display: flex;
    flex-direction: column;
    line-height: 1.25;
    min-width: 0;
  }
  .xp-tab-role {
    font-weight: 600;
    font-size: 0.92rem;
  }
  .xp-tab-org {
    font-size: 0.78rem;
    color: var(--text-dim);
  }

  /* ---- Panel ---- */
  .xp-panels {
    position: relative;
    min-height: 280px;
  }
  .xp-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: 1.6rem 1.8rem;
    animation: xpIn 0.4s var(--ease);
  }
  .xp-panel[hidden] {
    display: none;
  }
  @keyframes xpIn {
    from { opacity: 0; transform: translateY(12px); }
    to   { opacity: 1; transform: none; }
  }
  .xp-panel-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1rem;
  }
  .xp-panel-titles h3 {
    font-size: 1.3rem;
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex-wrap: wrap;
  }
  .xp-badge {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.5rem;
    border-radius: 99px;
    border: 1px solid var(--border-strong);
    color: var(--text-muted);
  }
  .xp-badge.work {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 50%, transparent);
  }
  .xp-badge.education {
    color: var(--accent-2);
    border-color: color-mix(in srgb, var(--accent-2) 50%, transparent);
  }
  .xp-org {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.92rem;
    color: var(--accent);
    margin-top: 0.35rem;
  }
  .xp-org i { font-size: 0.72rem; }
  .xp-org:hover { text-decoration: underline; }
  .xp-period {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-dim);
    white-space: nowrap;
    flex-shrink: 0;
    padding-top: 0.4rem;
  }
  .xp-points {
    margin: 0 0 1.2rem 1.1rem;
    color: var(--text-muted);
    font-size: 0.95rem;
  }
  .xp-points li { margin-bottom: 0.6rem; }
  .xp-points :global(.xp-link) {
    color: var(--accent);
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: color-mix(in srgb, var(--accent) 45%, transparent);
    transition: text-decoration-color var(--t-fast);
  }
  .xp-points :global(.xp-link:hover) {
    text-decoration-color: var(--accent);
  }
  .xp-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  /* ---- Mobile ---- */
  @media (max-width: 820px) {
    .xp {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .xp-dropdown { display: block; }
    .xp-tabs    { display: none;  }
    .xp-panel-head {
      flex-direction: column;
      gap: 0.3rem;
    }
    .xp-period { padding-top: 0; }
    .xp-panel  { padding: 1.2rem 1.1rem; }
    .xp-points { font-size: 0.88rem; }
  }
</style>

<script is:inline>
  (function () {
    var tabs   = Array.prototype.slice.call(document.querySelectorAll('.xp-tab'));
    var panels = Array.prototype.slice.call(document.querySelectorAll('.xp-panel'));
    if (!panels.length) return;

    function activate(idx) {
      tabs.forEach(function (t) {
        var on = t.dataset.idx === String(idx);
        t.setAttribute('aria-selected', on ? 'true' : 'false');
        t.tabIndex = on ? 0 : -1;
      });
      panels.forEach(function (p) {
        p.hidden = p.id !== 'xp-panel-' + idx;
      });
    }

    // ---- Desktop tab rail ----
    tabs.forEach(function (tab) {
      tab.addEventListener('click', function () {
        activate(parseInt(tab.dataset.idx, 10));
      });
      tab.addEventListener('keydown', function (e) {
        var order = tabs.map(function (t) { return parseInt(t.dataset.idx, 10); });
        var pos   = order.indexOf(parseInt(tab.dataset.idx, 10));
        var next  = null;
        if (e.key === 'ArrowDown' || e.key === 'ArrowRight')
          next = order[(pos + 1) % order.length];
        else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft')
          next = order[(pos - 1 + order.length) % order.length];
        if (next !== null) { e.preventDefault(); activate(next); tabs[next] && tabs[next].focus(); }
      });
    });

    // ---- Mobile custom dropdown ----
    var trigger   = document.getElementById('xp-dropdown-trigger');
    var menu      = document.getElementById('xp-dropdown-menu');
    var dropImg   = document.getElementById('xp-dropdown-img');
    var dropRole  = trigger  && trigger.querySelector('.xp-dropdown-role');
    var dropOrg   = trigger  && trigger.querySelector('.xp-dropdown-org');
    var dropItems = menu ? Array.prototype.slice.call(menu.querySelectorAll('.xp-dropdown-item')) : [];

    function closeMenu() {
      if (!trigger || !menu) return;
      trigger.setAttribute('aria-expanded', 'false');
      menu.hidden = true;
    }

    if (trigger && menu) {
      trigger.addEventListener('click', function (e) {
        e.stopPropagation();
        var open = trigger.getAttribute('aria-expanded') === 'true';
        trigger.setAttribute('aria-expanded', open ? 'false' : 'true');
        menu.hidden = open;
      });

      dropItems.forEach(function (item) {
        item.addEventListener('click', function () {
          var idx = parseInt(item.dataset.idx, 10);
          activate(idx);
          // update trigger display
          var role = item.querySelector('.xp-dropdown-item-role');
          var org  = item.querySelector('.xp-dropdown-item-org');
          var img  = item.querySelector('img');
          if (dropRole && role) dropRole.textContent = role.textContent;
          if (dropOrg  && org)  dropOrg.textContent  = org.textContent;
          if (dropImg  && img)  { dropImg.src = img.src; dropImg.alt = img.alt; }
          // update selected state
          dropItems.forEach(function (di) {
            di.setAttribute('aria-selected', di === item ? 'true' : 'false');
          });
          closeMenu();
        });
      });

      document.addEventListener('click', closeMenu);
    }
  })();
</script>
