---
const links = [
  { id: 'home', label: 'Home' },
  { id: 'about', label: 'About' },
  { id: 'experience', label: 'Experience' },
  { id: 'projects', label: 'Projects' },
  { id: 'contact', label: 'Contact' },
];
---

<nav class="sidenav" aria-label="Section navigation">
  <ul>
    {
      links.map((l) => (
        <li>
          <a href={`#${l.id}`} data-nav-dot={l.id} aria-label={l.label}>
            <span class="label">{l.label}</span>
            <span class="dot" />
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .sidenav {
    position: fixed;
    right: 1.6rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 50;
  }
  .sidenav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: flex-end;
  }
  .sidenav a {
    display: grid;
    grid-template-columns: 1fr 11px;
    align-items: center;
    gap: 0.7rem;
    color: var(--text-muted);
  }
  .label {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    text-align: right;
    white-space: nowrap;
    transition: color var(--t-fast);
  }
  .dot {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    border: 1.5px solid var(--text-dim);
    background: transparent;
    transition: all var(--t-fast);
  }
  .sidenav a:hover .label {
    color: var(--text);
  }
  .sidenav a:hover .dot {
    border-color: var(--accent);
    transform: scale(1.15);
  }
  .sidenav a.active .label {
    color: var(--accent);
  }
  .sidenav a.active .dot {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 12px var(--accent-glow);
  }

  @media (max-width: 1400px) {
    .sidenav {
      right: 0;
      left: 0;
      top: auto;
      bottom: 0;
      transform: none;
      background: rgba(8, 8, 12, 0.72);
      backdrop-filter: blur(14px);
      border-top: 1px solid var(--border);
      padding: 0.5rem 0;
      padding-bottom: calc(0.5rem + env(safe-area-inset-bottom, 0px));
    }
    .sidenav ul {
      flex-direction: row;
      justify-content: space-around;
      gap: 0;
      align-items: stretch;
    }
    .sidenav a {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.3rem;
    }
    .label {
      text-align: center;
      opacity: 0.65;
      font-size: 0.7rem;
    }
    .dot {
      display: none;
    }
    .sidenav a.active .label {
      color: var(--accent);
      opacity: 1;
    }
  }
</style>
